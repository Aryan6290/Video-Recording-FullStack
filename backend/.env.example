# App Settings
PROJECT_NAME="Locara EgoCentric Video Capture Backend"

# Database Configuration (Defaults to SQLite; update for Postgres/other DBs in production)
DATABASE_URL="sqlite:///./video_capture.db"
# Example PostgreSQL URL:
# DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/video_capture"

# JWT Auth Configuration
JWT_SECRET="locara-egocentric-video-super-secret-key-change-me"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AWS S3 Settings (Generate scoped credentials for PUT presigned URLs)
AWS_ACCESS_KEY_ID="mock-aws-access-key"
AWS_SECRET_ACCESS_KEY="mock-aws-secret-key"
AWS_REGION="us-east-1"
S3_BUCKET_NAME="locara-video-uploads"
PRESIGNED_URL_TTL_SECONDS=900
